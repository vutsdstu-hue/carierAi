generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum JobApplicationLogAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  DELETED
}

enum TestDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String

  // Profile fields used by the frontend
  name      String
  location  String
  avatar    String
  position  String
  experience String
  level     String
  joinDate  String

  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  skills         Skill[]
  testResults    TestResult[]
  jobApplications JobApplication[]
  jobApplicationLogs JobApplicationLog[] @relation("UserJobApplicationLogs")
}

model Skill {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name     String
  level    Int
  category String

  @@unique([userId, name, category])
}

model TestResult {
  id         String @id @default(uuid())
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  testId     String
  testTitle  String
  score      Int
  date       String
  answers    Json
  timeSpent  Int

  @@unique([userId, testId])
}

model TestDefinition {
  id          String         @id
  title       String
  category    String
  difficulty  TestDifficulty
  timeLimit   Int
  description String
  questions   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobApplication {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobId    String
  company  String
  position String
  status   String
  date     String
  createdAt DateTime @default(now())

  @@unique([userId, jobId])

  logs JobApplicationLog[] @relation("JobApplicationLogs")
}

model Job {
  id          String   @id @default(uuid())
  title       String
  company     String
  location    String
  salary      String
  type        String
  description String
  skills      String[]
  postedTime  String
  aiMatch     Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobApplicationLog {
  id               String               @id @default(uuid())
  jobApplicationId String
  jobId            String
  actorUserId      String
  action           JobApplicationLogAction
  fromStatus       String?
  toStatus         String?
  note             String?
  hidden           Boolean              @default(false)
  createdAt        DateTime             @default(now())

  jobApplication JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade, name: "JobApplicationLogs")
  actor          User           @relation(fields: [actorUserId], references: [id], onDelete: Cascade, name: "UserJobApplicationLogs")

  @@index([jobId])
  @@index([actorUserId])
}

